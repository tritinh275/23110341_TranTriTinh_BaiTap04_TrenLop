<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/public/css/custom.css" />
    <title>Shop giày - Trang chủ</title>
  </head>
  <body class="bg-slate-100 text-slate-800">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-blue-700">SneakerHub</a>
        <div class="flex items-center gap-4 text-sm">
          <div class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full">
            Xin chào, <strong><%= user.fullName %></strong> (thành viên)
          </div>
          <button
            id="logoutBtn"
            class="px-3 py-1.5 rounded-lg border border-slate-300 hover:bg-slate-50"
          >
            Đăng xuất
          </button>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-6 space-y-8">
      <section class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white rounded-2xl p-6">
        <h1 class="text-2xl md:text-3xl font-bold mb-2">Khuyến mãi mùa hè - giảm tới 30%</h1>
        <p class="opacity-95">Mua 2 đôi giảm thêm 5%, miễn phí vận chuyển toàn quốc.</p>
      </section>

      <section>
        <h2 class="text-xl font-semibold mb-3">Thông tin nổi bật</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <article class="bg-white rounded-xl p-4 shadow-sm">
            <p class="text-sm text-slate-500 mb-1">Khuyến mãi</p>
            <h3 class="font-semibold mb-2">Sản phẩm đang giảm giá</h3>
            <div class="text-sm text-slate-600"><%= promotions.map((p) => p.name).join(", ") %></div>
          </article>
          <article class="bg-white rounded-xl p-4 shadow-sm">
            <p class="text-sm text-slate-500 mb-1">Mới nhất</p>
            <h3 class="font-semibold mb-2">Sản phẩm vừa cập nhật</h3>
            <div class="text-sm text-slate-600"><%= newest.map((p) => p.name).join(", ") %></div>
          </article>
          <article class="bg-white rounded-xl p-4 shadow-sm">
            <p class="text-sm text-slate-500 mb-1">Bán chạy</p>
            <h3 class="font-semibold mb-2">Top xu hướng</h3>
            <div class="text-sm text-slate-600"><%= bestSellers.map((p) => p.name).join(", ") %></div>
          </article>
        </div>
      </section>

      <section class="bg-white rounded-2xl p-4 md:p-5 shadow-sm">
        <h2 class="text-xl font-semibold mb-4">Tìm kiếm và lọc sản phẩm</h2>
        <form id="filterForm" class="grid md:grid-cols-4 gap-3">
          <input
            class="border rounded-lg px-3 py-2"
            name="q"
            placeholder="Tìm theo tên/mô tả/danh mục"
          />
          <select class="border rounded-lg px-3 py-2" name="category">
            <option value="">Tất cả danh mục</option>
            <% categories.forEach((category) => { %>
            <option value="<%= category %>"><%= category %></option>
            <% }) %>
          </select>
          <input class="border rounded-lg px-3 py-2" name="minPrice" type="number" placeholder="Giá từ" />
          <input class="border rounded-lg px-3 py-2" name="maxPrice" type="number" placeholder="Giá đến" />
          <select class="border rounded-lg px-3 py-2" name="minRating">
            <option value="">Đánh giá từ</option>
            <option value="4">4 sao</option>
            <option value="4.5">4.5 sao</option>
            <option value="4.8">4.8 sao</option>
          </select>
          <select class="border rounded-lg px-3 py-2" name="sort">
            <option value="newest">Mới nhất</option>
            <option value="best-seller">Bán chạy</option>
            <option value="price-asc">Giá tăng dần</option>
            <option value="price-desc">Giá giảm dần</option>
          </select>
          <label class="flex items-center gap-2 text-sm">
            <input type="checkbox" name="onlyInStock" value="true" />
            Chỉ hiển thị còn hàng
          </label>
          <label class="flex items-center gap-2 text-sm">
            <input type="checkbox" name="isNew" value="true" />
            Chỉ sản phẩm mới
          </label>
          <label class="flex items-center gap-2 text-sm">
            <input type="checkbox" name="bestSeller" value="true" />
            Chỉ bán chạy
          </label>
          <button class="bg-blue-600 text-white rounded-lg px-3 py-2 font-medium" type="submit">
            Áp dụng bộ lọc
          </button>
        </form>
      </section>

      <section>
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-xl font-semibold">Danh sách sản phẩm</h2>
          <p class="text-sm text-slate-500" id="resultCount"></p>
        </div>
        <div id="productList" class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4"></div>
      </section>
    </main>

    <script>
      window.__PRODUCTS__ = <%- JSON.stringify(products) %>;
    </script>
    <script src="/public/js/home.js"></script>
  </body>
</html>
