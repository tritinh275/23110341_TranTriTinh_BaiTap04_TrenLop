<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/public/css/custom.css" />
    <title><%= product.name %> - Chi tiết sản phẩm</title>
  </head>
  <body class="bg-slate-100 text-slate-800">
    <header class="bg-white border-b border-slate-200 sticky top-0 z-10">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-blue-700">SneakerHub</a>
        <div class="text-sm bg-blue-50 text-blue-700 px-3 py-1 rounded-full">
          <%= user.fullName %> (thành viên)
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-6 space-y-8">
      <a href="/" class="text-sm text-blue-600 hover:underline">← Quay về trang chủ</a>

      <section class="grid lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl p-4 shadow-sm">
          <div class="swiper productSwiper rounded-xl overflow-hidden">
            <div class="swiper-wrapper">
              <% product.images.forEach((image) => { %>
              <div class="swiper-slide">
                <img src="<%= image %>" alt="<%= product.name %>" class="w-full h-[350px] object-cover" />
              </div>
              <% }) %>
            </div>
            <div class="swiper-pagination"></div>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-5 shadow-sm">
          <span class="inline-flex text-xs bg-slate-100 px-2 py-1 rounded-full mb-2">
            Danh mục: <strong class="ml-1"><%= product.category %></strong>
          </span>
          <h1 class="text-2xl font-bold mb-2"><%= product.name %></h1>
          <p class="text-slate-600 mb-4"><%= product.description %></p>

          <div class="mb-4">
            <span class="text-3xl font-bold text-blue-700"><%= product.price.toLocaleString("vi-VN") %>đ</span>
            <span class="text-slate-400 line-through ml-2"><%= product.originalPrice.toLocaleString("vi-VN") %>đ</span>
          </div>

          <div class="grid grid-cols-2 gap-3 text-sm mb-5">
            <div class="bg-slate-50 rounded-lg px-3 py-2">Tồn kho: <strong><%= product.stock %></strong></div>
            <div class="bg-slate-50 rounded-lg px-3 py-2">Đã bán: <strong><%= product.soldCount %></strong></div>
            <div class="bg-slate-50 rounded-lg px-3 py-2">Đánh giá: <strong><%= product.rating %> ★</strong></div>
            <div class="bg-slate-50 rounded-lg px-3 py-2">Khuyến mãi: <strong><%= product.promoLabel %></strong></div>
          </div>

          <div class="flex items-center gap-3">
            <span class="text-sm font-medium">Số lượng:</span>
            <div class="inline-flex items-center border rounded-lg overflow-hidden">
              <button id="decreaseQty" class="px-3 py-2 hover:bg-slate-100" type="button">-</button>
              <input id="qtyInput" class="w-14 text-center outline-none" value="1" />
              <button id="increaseQty" class="px-3 py-2 hover:bg-slate-100" type="button">+</button>
            </div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-xl font-semibold mb-3">Sản phẩm tương tự</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <% similarProducts.forEach((item) => { %>
          <article class="bg-white rounded-xl overflow-hidden shadow-sm">
            <img src="<%= item.images[0] %>" alt="<%= item.name %>" class="w-full h-40 object-cover" />
            <div class="p-3">
              <h3 class="font-semibold text-sm mb-1"><%= item.name %></h3>
              <p class="text-blue-700 font-semibold mb-2"><%= item.price.toLocaleString("vi-VN") %>đ</p>
              <a class="text-sm text-blue-600 hover:underline" href="/products/<%= item.id %>">Xem chi tiết</a>
            </div>
          </article>
          <% }) %>
        </div>
      </section>
    </main>

    <script>
      window.__PRODUCT__ = <%- JSON.stringify(product) %>;
    </script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="/public/js/detail.js"></script>
  </body>
</html>
